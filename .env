# App runtime
FLASK_ENV=production
PORT=5000

# Flask / session secret
SECRET_KEY=replace_with_secure_random_hex

# OpenAI or other LLM provider
OPENAI_API_KEY=replace_with_your_openai_api_key

# Storage (set STORAGE_TYPE=local or s3)
STORAGE_TYPE=local
# If using S3-compatible storage, set these:
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Database (optional)
DATABASE_URL=sqlite:///data/app.db

# Upload limits and allowed types
MAX_UPLOAD_SIZE_BYTES=10485760
ALLOWED_EXTENSIONS=.pdf,.csv,.xls,.xlsx

# Authentication / API access
JWT_SECRET=replace_with_secure_random_hex
ADMIN_API_TOKEN=replace_with_admin_token_for_local_testing

# Logging and monitoring
LOG_LEVEL=INFO
SENTRY_DSN=

# App behavior toggles
ENABLE_OCR=true
OCR_DPI=200
